# ─── Firebird (ERP) ──────────────────────────────────────────────────────────
FIREBIRD_HOST=localhost
FIREBIRD_PORT=3050
# Caminho LOCAL do arquivo no servidor. Use barras invertidas duplas ou simples;
# o Node aceita as duas em string de .env.
FIREBIRD_DATABASE=C:\ERP\DADOS\ERP.FDB
FIREBIRD_USER=SYSDBA
FIREBIRD_PASSWORD=masterkey

# Tabela/view de clientes. O ERP tem a camada ERP_CLIENTE pronta; se ela não
# existir, aponte para a tabela crua (ex.: CLIENTES) e ajuste o mapeamento de
# colunas em src/routes/clientes.js.
ERP_TABELA_CLIENTES=ERP_CLIENTE

# ─── API local ───────────────────────────────────────────────────────────────
API_PORT=3333
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_TOKEN=troque_por_um_secret_de_64_chars

# Origens permitidas no CORS, separadas por vírgula. Deixe vazio para bloquear
# tudo que não seja server-to-server (o caso normal desta API).
CORS_ORIGINS=

# ─── FlowCRM (destino) ───────────────────────────────────────────────────────
CRM_SYNC_URL=https://qwigwpookuhxhehzewti.supabase.co/functions/v1/erp-sync
# Token gerado no CRM em Integrações → ERP → "Gerar token"
CRM_TOKEN=cole_o_token_do_crm_aqui

# ─── Operação ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Tamanho do lote enviado ao CRM por requisição.
SYNC_BATCH_SIZE=500

# Sync automático. Deixe vazio para desligar e disparar só manualmente via
# POST /sync/clientes. Exemplo (3h da manhã): 0 3 * * *
SYNC_CRON=
