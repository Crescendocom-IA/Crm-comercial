# ============================================
# FlowCRM — Variáveis de Ambiente
# ============================================
# Copie este arquivo como .env e preencha os valores
# Encontre estes valores em: Supabase Dashboard → Project Settings → API

# Supabase (obrigatórias)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_PROJECT_ID=your-project-id

# Edge Functions (configurar em Supabase Dashboard → Edge Functions → Secrets)
# ANTHROPIC_API_KEY=sk-ant-...          # Para AI Copilot, Insights, Email e Sales Manager
# GOOGLE_CLIENT_ID=...                  # Para Google Calendar / Gmail sync
# GOOGLE_CLIENT_SECRET=...              # Para Google Calendar / Gmail sync
# SLACK_BOT_TOKEN=xoxb-...              # Para notificações Slack
# EVOLUTION_API_URL=https://...         # Para WhatsApp
# EVOLUTION_API_KEY=...                 # Para WhatsApp
# SENTRY_DSN=https://...@sentry.io/... # Para monitoramento de erros
